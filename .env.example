# ─── DATABASE ────────────────────────────────────────────────────────────────
# Azure PostgreSQL flexible server connection string
DATABASE_URL="postgresql://USER:PASSWORD@HOST.postgres.database.azure.com:5432/DBNAME?sslmode=require"

# ─── APP ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-app.azurewebsites.net

# ─── AUTH ────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_here

# ─── CLOUDINARY (platform-level media) ───────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name

# ─── RAZORPAY (platform billing) ─────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx

# ─── EMAIL (platform SMTP fallback) ──────────────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your_sendgrid_api_key
SMTP_FROM=no-reply@yourdomain.com

# ─── GOOGLE RECAPTCHA ────────────────────────────────────────────────────────
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_site_key
RECAPTCHA_SECRET_KEY=your_secret_key
